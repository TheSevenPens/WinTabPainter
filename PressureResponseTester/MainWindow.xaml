<Window x:Class="WinTabPressureTester.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="http://oxyplot.org/wpf"
        mc:Ignorable="d"
        Title="WinTab Pressure Response Tester"
        Height="850"
        Width="1200"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        ResizeMode="CanResize"
        Background="White"
        PreviewKeyDown="Window_PreviewKeyDown">
    
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- Ribbon Bar -->
        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#F0F0F0" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="button_record" Content="Record Current (R)" Click="button_record_Click" Padding="12,8" Margin="0,0,5,0" Background="DodgerBlue" Foreground="White" FontWeight="Bold"/>
                <Button x:Name="button_load_sample_data" Content="Load Sample Data (L)" Click="button_load_sample_data_Click" Padding="12,8" Margin="0,0,5,0" Background="CornflowerBlue" Foreground="White" FontWeight="Bold"/>
                <Button x:Name="button_clearlast" Content="Clear Last (C)" Click="button_clearlast_Click" Padding="12,8" Margin="0,0,5,0" Background="Orange" Foreground="White" FontWeight="Bold"/>
                <Button x:Name="button_clearlog" Content="Clear All (A)" Click="button_clearlog_Click" Padding="12,8" Background="Tomato" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Left Panel: Tablet Readings -->
        <StackPanel Grid.Row="1" Grid.Column="0" Margin="10">
            <GroupBox Header="Tablet Readings" Margin="0,0,0,10">
                <StackPanel Margin="10">
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Pressure (raw):" FontWeight="Bold"/>
                        <Label x:Name="label_pressure_raw" Grid.Column="1" Content="-----" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Pressure (normalized):" FontWeight="Bold"/>
                        <Label x:Name="label_normalized_pressure" Grid.Column="1" Content="-----"/>
                    </Grid>

                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Pressure (Moving Avg):" FontWeight="Bold"/>
                        <Label x:Name="label_normalizedpressure_ma" Grid.Column="1" Content="-----"/>
                    </Grid>

                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Azimuth:" FontWeight="Bold"/>
                        <Label x:Name="label_or_azimuth" Grid.Column="1" Content="-----"/>
                    </Grid>

                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Altitude:" FontWeight="Bold"/>
                        <Label x:Name="label_or_altitude" Grid.Column="1" Content="-----"/>
                    </Grid>

                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Tilt X:" FontWeight="Bold"/>
                        <Label x:Name="label_tiltx" Grid.Column="1" Content="-----"/>
                    </Grid>

                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Tilt Y:" FontWeight="Bold"/>
                        <Label x:Name="label_tilty" Grid.Column="1" Content="-----"/>
                    </Grid>

                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Force:" FontWeight="Bold"/>
                        <Label x:Name="label_force" Grid.Column="1" Content="-----" FontSize="14" FontWeight="Bold" Foreground="DarkRed"/>
                    </Grid>

                    <GroupBox Header="Button State" Margin="0,10,0,0">
                        <StackPanel Margin="10">
                            <CheckBox x:Name="checkBox_tipdown" Content="Tip Down" Margin="0,5" IsEnabled="False"/>
                            <CheckBox x:Name="checkBox_lowerbuttondown" Content="Lower Button Down" Margin="0,5" IsEnabled="False"/>
                            <CheckBox x:Name="checkBox_upperbuttondown" Content="Upper Button Down" Margin="0,5" IsEnabled="False"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Scale Readings" Margin="0,10,0,0">
                <StackPanel Margin="10">
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="COM Port:" FontWeight="Bold"/>
                        <ComboBox x:Name="comboBoxcomport" Grid.Column="1"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,10">
                        <Button x:Name="button_start" Content="Start (S)" Click="button_start_Click" Padding="10,5" Margin="0,0,5,0" Background="LimeGreen" Foreground="White" FontWeight="Bold"/>
                        <Button x:Name="button_stop" Content="Stop (T)" Click="button_stop_Click" Padding="10,5" Background="Red" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <!-- Center Panel: Chart -->
        <GroupBox Grid.Row="1" Grid.Column="1" Header="Pressure Response" Margin="10">
            <oxy:PlotView x:Name="plotView1" Margin="10" PreviewMouseDown="plotView1_MouseDown"/>
        </GroupBox>

        <!-- Right Panel: Data Recording -->
        <StackPanel Grid.Row="1" Grid.Column="2" Margin="10">
            <GroupBox Header="Data" Margin="0,0,0,10">
                <StackPanel Margin="10">
					<Grid Margin="0,5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="100"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<Label Grid.Column="0" Content="Records:" FontWeight="Bold"/>
						<Label x:Name="label_recordcount" Grid.Column="1" Content="0" FontWeight="Bold" FontSize="14"/>
					</Grid>

					<TextBox x:Name="textBox_log" Height="150" TextWrapping="Wrap" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Margin="0,5" FontFamily="Consolas" FontSize="10"/>


                    <GroupBox Header="Metadata" Margin="0,10,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                            <StackPanel Margin="10">
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="Brand:" FontWeight="Bold" FontSize="10"/>
                                    <TextBox x:Name="textBox_brand" Grid.Column="1" Text="BRAND" FontSize="10" Margin="5,0"/>
                                </Grid>

                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="Pen:" FontWeight="Bold" FontSize="10"/>
                                    <TextBox x:Name="textBox_Pen" Grid.Column="1" Text="PEN" FontSize="10" Margin="5,0"/>
                                </Grid>

                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="ID:" FontWeight="Bold" FontSize="10"/>
                                    <TextBox x:Name="textBox_inventoryid" Grid.Column="1" Text="--P.0000" FontSize="10" Margin="5,0"/>
                                </Grid>

                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="Date:" FontWeight="Bold" FontSize="10"/>
                                    <TextBox x:Name="textBox_date" Grid.Column="1" Text="2024-01-01" FontSize="10" Margin="5,0"/>
                                </Grid>

                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="User:" FontWeight="Bold" FontSize="10"/>
                                    <TextBox x:Name="textBox_User" Grid.Column="1" FontSize="10" Margin="5,0"/>
                                </Grid>

                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="Tablet:" FontWeight="Bold" FontSize="10"/>
                                    <TextBox x:Name="textBox_Tablet" Grid.Column="1" FontSize="10" Margin="5,0"/>
                                </Grid>

                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="Driver:" FontWeight="Bold" FontSize="10"/>
                                    <TextBox x:Name="textBox_driver" Grid.Column="1" FontSize="10" Margin="5,0"/>
                                </Grid>

                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="OS:" FontWeight="Bold" FontSize="10"/>
                                    <TextBox x:Name="textBox_OS" Grid.Column="1" FontSize="10" Margin="5,0"/>
                                </Grid>

                                <Separator Margin="0,10"/>

                                <Button x:Name="button_copy_chart" Content="Copy Chart Title" Click="button_copy_chart_Click" Padding="5,3" FontSize="10" Margin="0,5"/>

                                <Button x:Name="button_copytext" Content="Copy to Clipboard" Click="button_copytext_Click" Padding="5,3" FontSize="10" Margin="0,5"/>

                                <Button x:Name="button_export" Content="Export JSON" Click="button_export_Click" Padding="5,3" FontSize="10" Margin="0,5" Background="Green" Foreground="White"/>
                            </StackPanel>
                        </ScrollViewer>
                    </GroupBox>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </Grid>
</Window>
