<Window x:Class="WinTabPressureTester.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="http://oxyplot.org/wpf"
        mc:Ignorable="d"
        Title=" Pressure Response Tester"
        Height="850"
        Width="1200"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        ResizeMode="CanResize"
        Background="White"
        PreviewKeyDown="Window_PreviewKeyDown"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="148.778"/>
            <ColumnDefinition Width="251.222"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Tablet Readings -->
        <StackPanel Grid.Row="1" Grid.Column="0" Margin="10,10,10,10" Grid.ColumnSpan="2">
            <GroupBox Header="Tablet Readings" Margin="0,0,0,10">
                <StackPanel Margin="10">
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Log Pressure (raw):" FontWeight="Bold"/>
                        <Label x:Name="label_pressure_raw" Grid.Column="1" Content="-----" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Log Pressure (norm):" FontWeight="Bold"/>
                        <Label x:Name="label_normalized_pressure" Grid.Column="1" Content="-----"/>
                    </Grid>

                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Log Pressure (smooth):" FontWeight="Bold"/>
                        <Label x:Name="label_normalizedpressure_ma" Grid.Column="1" Content="-----"/>
                    </Grid>

                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Phys Presssure:" FontWeight="Bold"/>
                        <Label x:Name="label_force" Grid.Column="1" Content="-----" FontSize="14" FontWeight="Bold" Foreground="DarkRed"/>
                    </Grid>

                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Azimuth:" FontWeight="Bold"/>
                        <Label x:Name="label_or_azimuth" Grid.Column="1" Content="-----"/>
                    </Grid>

                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Altitude:" FontWeight="Bold"/>
                        <Label x:Name="label_or_altitude" Grid.Column="1" Content="-----"/>
                    </Grid>

                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Tilt X:" FontWeight="Bold"/>
                        <Label x:Name="label_tiltx" Grid.Column="1" Content="-----"/>
                    </Grid>

                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Tilt Y:" FontWeight="Bold"/>
                        <Label x:Name="label_tilty" Grid.Column="1" Content="-----"/>
                    </Grid>

                    <GroupBox Header="Button State" Margin="0,10,0,0">
                        <StackPanel Margin="10">
                            <CheckBox x:Name="checkBox_tipdown" Content="Tip" Margin="0,5" IsEnabled="False"/>
                            <CheckBox x:Name="checkBox_lowerbuttondown" Content="Button1" Margin="0,5" IsEnabled="False"/>
                            <CheckBox x:Name="checkBox_upperbuttondown" Content="Button1" Margin="0,5" IsEnabled="False"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Scale control" Margin="0,10,0,0">
                <StackPanel Margin="10">
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="COM Port:" FontWeight="Bold"/>
                        <ComboBox x:Name="comboBoxcomport" Grid.Column="1"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,10">
                        <Button x:Name="button_start" Content="Start (S)" Click="button_start_Click" Padding="8,5" MinHeight="32" Margin="0,0,5,0"/>
                        <Button x:Name="button_stop" Content="Stop (T)" Click="button_stop_Click" Padding="8,5" MinHeight="32"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <!-- Center Panel: Chart -->
        <GroupBox Grid.Row="1" Grid.Column="2" Header="Pressure Response" Margin="10,10,10,10">
            <oxy:PlotView x:Name="plotView1" Margin="10" PreviewMouseDown="plotView1_MouseDown" PreviewMouseWheel="plotView1_PreviewMouseWheel"/>
        </GroupBox>

        <!-- Right Panel: Data Recording -->
        <StackPanel Grid.Row="1" Grid.Column="3" Margin="10,10,10,10">
                <StackPanel Margin="10">
                    <Label Content="Data" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <!-- Ribbon Buttons -->
                    <WrapPanel Margin="0,0,0,10">
                        <Button x:Name="button_record" Content="Record (R)" Click="button_record_Click" Padding="8,3" MinHeight="28" MinWidth="80" Margin="0,0,5,5"/>
                        <Button x:Name="button_load_sample_data" Content="Sample (L)" Click="button_load_sample_data_Click" Padding="8,3" MinHeight="28" MinWidth="80" Margin="0,0,5,5"/>
                        <Button x:Name="button_clearlast" Content="Clear Last (C)" Click="button_clearlast_Click" Padding="8,3" MinHeight="28" MinWidth="80" Margin="0,0,5,5"/>
                        <Button x:Name="button_clearlog" Content="Clear All (A)" Click="button_clearlog_Click" Padding="8,3" MinHeight="28" MinWidth="80" Margin="0,0,5,5"/>
                        <Button x:Name="button_copytext" Content="Copy" Click="button_copytext_Click" Padding="8,3" MinHeight="28" MinWidth="80" Margin="0,0,5,5"/>
                        <Button x:Name="button_save" Content="Save (Ctrl+S)" Click="button_save_Click" Padding="8,3" MinHeight="28" MinWidth="80" Margin="0,0,5,5" IsEnabled="False"/>
                        <Button x:Name="button_export" Content="Export" Click="button_export_Click" Padding="8,3" MinHeight="28" MinWidth="80"/>
                    </WrapPanel>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Records:" FontWeight="Bold"/>
                        <Label x:Name="label_recordcount" Grid.Column="1" Content="0" FontWeight="Bold" FontSize="14"/>
                    </Grid>

                    <DataGrid x:Name="dataGrid_records" Height="150" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" Margin="0,5" FontFamily="Consolas" FontSize="10" GridLinesVisibility="All" BorderThickness="1" BorderBrush="#CCCCCC">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Physical (gf)" Binding="{Binding PhysicalPressure, StringFormat=0.0}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Logical (%)" Width="*" IsReadOnly="True">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="LogicalPressure" StringFormat="{}{0:P2}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>


                    <StackPanel Margin="10">
                        <!-- First Row: Brand and ID -->
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Content="Brand:" FontWeight="Bold" FontSize="10" Padding="0,0,0,2"/>
                                <TextBox x:Name="textBox_brand" Text="BRAND" FontSize="10" Padding="5,3"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Content="ID:" FontWeight="Bold" FontSize="10" Padding="0,0,0,2"/>
                                <TextBox x:Name="textBox_inventoryid" Text="--P.0000" FontSize="10" Padding="5,3"/>
                            </StackPanel>
                        </Grid>

                        <!-- Second Row: Pen and User -->
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Content="Pen:" FontWeight="Bold" FontSize="10" Padding="0,0,0,2"/>
                                <TextBox x:Name="textBox_Pen" Text="PEN" FontSize="10" Padding="5,3"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Content="User:" FontWeight="Bold" FontSize="10" Padding="0,0,0,2"/>
                                <TextBox x:Name="textBox_User" FontSize="10" Padding="5,3"/>
                            </StackPanel>
                        </Grid>

                        <!-- Third Row: Family and Tablet -->
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Content="Family:" FontWeight="Bold" FontSize="10" Padding="0,0,0,2"/>
                                <TextBox x:Name="textBox_penfamily" FontSize="10" Padding="5,3"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Content="Tablet:" FontWeight="Bold" FontSize="10" Padding="0,0,0,2"/>
                                <TextBox x:Name="textBox_Tablet" FontSize="10" Padding="5,3"/>
                            </StackPanel>
                        </Grid>

                        <!-- Fourth Row: Date and Driver -->
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Content="Date:" FontWeight="Bold" FontSize="10" Padding="0,0,0,2"/>
                                <TextBox x:Name="textBox_date" Text="2024-01-01" FontSize="10" Padding="5,3"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Content="Driver:" FontWeight="Bold" FontSize="10" Padding="0,0,0,2"/>
                                <TextBox x:Name="textBox_driver" FontSize="10" Padding="5,3"/>
                            </StackPanel>
                        </Grid>

                        <!-- Fifth Row: OS -->
                        <Grid Margin="0,0,0,5">
                            <StackPanel>
                                <Label Content="OS:" FontWeight="Bold" FontSize="10" Padding="0,0,0,2"/>
                                <TextBox x:Name="textBox_OS" FontSize="10" Padding="5,3"/>
                            </StackPanel>
                        </Grid>

                        <!-- Sixth Row: Tags -->
                        <Grid Margin="0,0,0,10">
                            <StackPanel>
                                <Label Content="Tags:" FontWeight="Bold" FontSize="10" Padding="0,0,0,2"/>
                                <TextBox x:Name="textBox_tags" FontSize="10" Padding="5,3"/>
                            </StackPanel>
                        </Grid>

                        <!-- Seventh Row: Notes -->
                        <Grid Margin="0,0,0,10">
                            <StackPanel>
                                <Label Content="Notes:" FontWeight="Bold" FontSize="10" Padding="0,0,0,2"/>
                                <TextBox x:Name="textBox_notes" Height="50" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontSize="10" Padding="5,3" AcceptsReturn="True"/>
                            </StackPanel>
                        </Grid>

                        <!-- Buttons Row -->

                    </StackPanel>
                </StackPanel>
        </StackPanel>
    </Grid>
</Window>
