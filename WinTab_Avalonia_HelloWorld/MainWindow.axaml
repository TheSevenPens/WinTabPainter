<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="WinTab_Avalonia_HelloWorld.MainWindow"
        Title="WinTab Avalonia Hello World" Height="450" Width="800">
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Background="#EEEEEE" Padding="5" Margin="5">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Sx:" FontWeight="Bold" Margin="0,0,5,0"/>
                <TextBlock x:Name="ValGx" Text="0" MinWidth="40" Margin="0,0,15,0"/>

                <TextBlock Text="Sy:" FontWeight="Bold" Margin="0,0,5,0"/>
                <TextBlock x:Name="ValGy" Text="0" MinWidth="40" Margin="0,0,15,0"/>

                <TextBlock Text="Cx:" FontWeight="Bold" Margin="0,0,5,0"/>
                <TextBlock x:Name="ValCx" Text="0" MinWidth="40" Margin="0,0,15,0"/>

                <TextBlock Text="Cy:" FontWeight="Bold" Margin="0,0,5,0"/>
                <TextBlock x:Name="ValCy" Text="0" MinWidth="40" Margin="0,0,15,0"/>

                <TextBlock Text="Z:" FontWeight="Bold" Margin="0,0,5,0"/>
                <TextBlock x:Name="ValZ" Text="0" MinWidth="30" Margin="0,0,15,0"/>

                <TextBlock Text="PRS:" FontWeight="Bold" Margin="0,0,5,0"/>
                <TextBlock x:Name="ValP" Text="0" MinWidth="40" Margin="0,0,15,0"/>

                <TextBlock Text="TAz:" FontWeight="Bold" Margin="0,0,5,0"/>
                <TextBlock x:Name="ValAz" Text="0" MinWidth="30" Margin="0,0,15,0"/>

                <TextBlock Text="TAlt:" FontWeight="Bold" Margin="0,0,5,0"/>
                <TextBlock x:Name="ValAlt" Text="0" MinWidth="30" Margin="0,0,15,0"/>

                <TextBlock Text="BTN:" FontWeight="Bold" Margin="0,0,5,0"/>
                <TextBlock x:Name="ValBtn" Text="None" MinWidth="100"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#EEEEEE" Padding="20" Margin="5">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Image x:Name="CanvasImage"
                       Stretch="None"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
